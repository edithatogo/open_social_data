{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Dashboard",
  "packageRules": [
    {
      "description": "Group Rust minor/patch updates",
      "matchManagers": ["cargo"],
      "groupName": "Rust dependencies",
      "groupSlug": "rust-deps",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Keep major Rust upgrades manual",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Group npm/docs tooling updates",
      "matchManagers": ["npm"],
      "groupName": "Docs tooling",
      "groupSlug": "docs-tooling",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Enable lockfile maintenance",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "enabled": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 9am on monday"]
  },
  "schedule": ["before 9am on monday"],
  "timezone": "Pacific/Auckland"
}