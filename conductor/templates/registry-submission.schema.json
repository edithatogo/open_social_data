{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legal-nz.local/conductor/registry-submission.schema.json",
  "title": "Registry submission manifest",
  "type": "object",
  "required": [
    "artifact",
    "version",
    "owner",
    "registries",
    "evidence"
  ],
  "properties": {
    "artifact": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "submitted", "accepted", "rejected", "deferred", "blocked"]
    },
    "registries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["required", "optional", "submitted", "accepted", "rejected", "deferred", "not_applicable", "blocked"]
          },
          "url": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
